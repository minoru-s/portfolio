---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogCard from '../../components/BlogCard.astro';
import * as data from '../../data/ja';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const b = import.meta.env.BASE_URL;
---

<Layout title="Blog" lang="ja">
  <Header currentLang="ja" />

  <main class="relative z-10 pt-28 pb-20"
        style="background: linear-gradient(180deg, rgba(124,58,237,0.09) 0%, rgba(124,58,237,0.03) 25%, transparent 50%);">

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-10">
      <a href={b} class="inline-flex items-center text-sm text-appleBlue hover:underline font-medium mb-6">
        <i class="fa-solid fa-arrow-left mr-2"></i>ホームへ
      </a>
      <div class="flex items-center gap-5 mt-2">
        <div class="w-16 h-16 flex items-center justify-center rounded-2xl shrink-0"
             style="background: rgba(124,58,237,0.1); border: 1px solid rgba(124,58,237,0.2);">
          <i class="fa-solid fa-pen-nib text-2xl" style="color: #7c3aed;"></i>
        </div>
        <div>
          <h1 class="text-4xl font-bold text-appleDark tracking-tight">Blog</h1>
          <p class="text-appleGray mt-1">技術・UX・日常のこと — 全 {posts.length} 件</p>
        </div>
      </div>
    </div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      {posts.length === 0 ? (
        <div class="glass-panel p-16 text-center fade-in-section">
          <i class="fa-solid fa-pen-nib text-3xl mb-4" style="color:rgba(124,58,237,0.25);"></i>
          <p class="text-appleGray">記事はまだありません</p>
        </div>
      ) : (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-0 fade-in-section">
          {posts.map(post => (
            <BlogCard
              title={post.data.title}
              summary={post.data.summary}
              date={post.data.date}
              tags={post.data.tags}
              slug={post.id}
              thumbnail={post.data.thumbnail}
            />
          ))}
        </div>
      )}

      <div class="mt-20 pt-10 border-t border-black/5 text-center fade-in-section">
        <p class="text-xs text-appleGray mb-5 tracking-wider uppercase">他のコンテンツを探索する</p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href={`${b}research/`} class="inline-flex items-center px-5 py-2.5 glass-button rounded-full text-sm font-medium text-appleDark hover:text-appleBlue transition-all">
            <i class="fa-solid fa-flask mr-2 text-xs"></i>Research
          </a>
          <a href={`${b}projects/`} class="inline-flex items-center px-5 py-2.5 glass-button rounded-full text-sm font-medium text-appleDark hover:text-appleBlue transition-all">
            <i class="fa-solid fa-code mr-2 text-xs"></i>Projects
          </a>
          <a href={`${b}achievements/`} class="inline-flex items-center px-5 py-2.5 glass-button rounded-full text-sm font-medium text-appleDark hover:text-appleBlue transition-all">
            <i class="fa-solid fa-trophy mr-2 text-xs"></i>Achievements
          </a>
          <a href={b} class="inline-flex items-center px-5 py-2.5 glass-button rounded-full text-sm font-medium text-appleDark hover:text-appleBlue transition-all">
            <i class="fa-solid fa-house mr-2 text-xs"></i>ホームへ
          </a>
        </div>
      </div>
    </div>

  </main>

  <Footer socials={data.socials} lang="ja" />
</Layout>
