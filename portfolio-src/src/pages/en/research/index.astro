---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import * as data from '../../../data/en';

const research = (await getCollection('research', ({ id }) => id.startsWith('en/')))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const b = import.meta.env.BASE_URL;
---

<Layout title="Research" lang="en">
  <Header currentLang="en" />

  <main class="relative z-10 pt-28 pb-20"
        style="background: linear-gradient(180deg, rgba(0,102,204,0.09) 0%, rgba(0,102,204,0.03) 25%, transparent 50%);">

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-10">
      <a href={`${b}en/`} class="inline-flex items-center text-sm text-appleBlue hover:underline font-medium mb-6">
        <i class="fa-solid fa-arrow-left mr-2"></i>Back to Home
      </a>
      <div class="flex items-center gap-5 mt-2">
        <div class="w-16 h-16 flex items-center justify-center rounded-2xl shrink-0"
             style="background: rgba(0,102,204,0.1); border: 1px solid rgba(0,102,204,0.2);">
          <i class="fa-solid fa-flask text-2xl text-appleBlue"></i>
        </div>
        <div>
          <h1 class="text-4xl font-bold text-appleDark tracking-tight">Research</h1>
          <p class="text-appleGray mt-1">All {research.length} research activities</p>
        </div>
      </div>
    </div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-6 mt-0 fade-in-section">
        {research.map(item => (
          <ProjectCard
            title={item.data.title}
            summary={item.data.summary}
            image={item.data.hero}
            stack={item.data.stack}
            highlights={item.data.highlights}
            href={`${b}en/research/${item.id.replace('en/', '')}/`}
            isResearch={true}
            ctaLabel="Learn More"
            directLink={true}
          />
        ))}
      </div>

      <div class="mt-20 pt-10 border-t border-black/5 text-center fade-in-section">
        <p class="text-xs text-appleGray mb-5 tracking-wider uppercase">Continue exploring</p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href={`${b}en/projects/`} class="inline-flex items-center px-5 py-2.5 glass-button rounded-full text-sm font-medium text-appleDark hover:text-appleBlue transition-all">
            <i class="fa-solid fa-code mr-2 text-xs"></i>Projects
          </a>
          <a href={`${b}en/achievements/`} class="inline-flex items-center px-5 py-2.5 glass-button rounded-full text-sm font-medium text-appleDark hover:text-appleBlue transition-all">
            <i class="fa-solid fa-trophy mr-2 text-xs"></i>Achievements
          </a>
          <a href={`${b}en/`} class="inline-flex items-center px-5 py-2.5 glass-button rounded-full text-sm font-medium text-appleDark hover:text-appleBlue transition-all">
            <i class="fa-solid fa-house mr-2 text-xs"></i>Home
          </a>
        </div>
      </div>
    </div>

  </main>

  <Footer socials={data.socials} lang="en" />
</Layout>
