---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';
import AchievementCard from '../components/AchievementCard.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import * as data from '../data/ja';

const allProjects = (await getCollection('projects', ({ id }) => id.startsWith('ja/')))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const allResearch = (await getCollection('research', ({ id }) => id.startsWith('ja/')))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const allPosts = (await getCollection('blog')).filter(p => !p.data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const featuredProjects = allProjects.slice(0, 3);
const achData = data.achievements.map(a => ({ title: a.title, date: a.date, summary: a.summary, details: a.details }));
const b = import.meta.env.BASE_URL;
---

<Layout title="Home" lang="ja">
  <Header currentLang="ja" />

  <main class="relative z-10 pt-32 pb-20 px-4 sm:px-6 lg:px-8">

    <!-- Hero -->
    <section id="hero" class="min-h-[80vh] flex items-center justify-center max-w-5xl mx-auto mb-32 fade-in-section">
      <div class="w-full grid md:grid-cols-2 gap-12 items-center">
        <div class="space-y-6 order-2 md:order-1 text-center md:text-left">
          <p class="text-appleBlue font-semibold tracking-wide text-sm">Hello, I'm</p>
          <h1 class="flex flex-col gap-1 pb-1">
            <span class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight text-gradient">{data.profile.name}</span>
            <span class="text-2xl font-medium text-appleGray tracking-normal">{data.profile.englishName}</span>
          </h1>
          <h2 class="text-xl md:text-2xl text-appleGray font-medium">{data.profile.title}</h2>
          <p class="text-appleDark/80 leading-relaxed max-w-lg mx-auto md:mx-0 text-lg">{data.profile.description}</p>
          <div class="flex flex-wrap justify-center md:justify-start gap-4 pt-4">
            <a href={`${b}research/`} class="inline-flex items-center px-7 py-3.5 text-base font-semibold rounded-full glass-button text-appleDark hover:text-appleBlue transition-all hover:-translate-y-0.5">
              Researchを見る
            </a>
            <a href="#contact" class="inline-flex items-center px-7 py-3.5 text-base font-semibold rounded-full glass-button text-appleDark hover:text-appleBlue transition-all hover:-translate-y-0.5">
              お問い合わせ
            </a>
          </div>
        </div>
        <div class="order-1 md:order-2 flex justify-center">
          <div class="relative w-64 h-64 md:w-72 md:h-72 overflow-hidden glass-panel p-2 transform rotate-3 hover:rotate-0 transition-all duration-500" style="border-radius: 2rem;">
            <img src={`${b}${data.profile.image.slice(1)}`} alt="Minoru SAITO" class="w-full h-full object-cover" style="border-radius: 1.5rem;" />
          </div>
        </div>
      </div>
    </section>

    <!-- About -->
    <section id="about" class="max-w-4xl mx-auto mb-32 fade-in-section">
      <h2 class="text-3xl font-bold mb-2 text-appleDark tracking-tight">About Me</h2>
      <div class="w-12 h-1 bg-appleBlue rounded-full mb-8"></div>
      <div class="glass-panel p-8 md:p-10 text-appleDark/90 leading-relaxed text-lg">
        <div class="space-y-4 mb-8">
          <p>{data.aboutText}</p>
          <p>{data.aboutText2}</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-6 border-t border-black/5">
          {data.aboutInfo.map(item => (
            <div class="flex items-center text-appleDark/80">
              <div class="w-8 text-center text-appleBlue"><i class={item.icon}></i></div>
              <span class="text-sm font-medium ml-2">{item.text}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Skills -->
    <section id="skills" class="max-w-5xl mx-auto mb-32 fade-in-section">
      <div class="mb-8">
        <h2 class="text-3xl font-bold mb-2 text-appleDark tracking-tight">Skills</h2>
        <div class="w-12 h-1 bg-appleBlue rounded-full"></div>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {data.skills.map(category => (
          <div class="glass-panel p-6">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-9 h-9 flex items-center justify-center glass-button rounded-xl text-appleBlue text-sm">
                <i class={category.icon}></i>
              </div>
              <h3 class="font-bold text-appleDark">{category.category}</h3>
            </div>
            <div class="flex flex-wrap gap-2">
              {category.items.map(skill => (
                <span
                  class={`relative inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium border cursor-default group/chip ${
                    skill.level === 3 ? 'bg-appleBlue/10 text-appleBlue border-appleBlue/25' :
                    skill.level === 2 ? 'bg-black/8 text-appleDark/75 border-black/10' :
                    'bg-black/4 text-appleDark/35 border-black/8'
                  }`}
                >
                  <span class={`w-1.5 h-1.5 rounded-full shrink-0 ${
                    skill.level === 3 ? 'bg-appleBlue' :
                    skill.level === 2 ? 'bg-appleGray/60' :
                    'bg-appleDark/20'
                  }`}></span>
                  {skill.name}
                  {skill.note && (
                    <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 px-2.5 py-1.5 bg-white/90 backdrop-blur-md border border-black/10 shadow-md text-appleDark/80 text-[10px] font-medium rounded-lg whitespace-nowrap opacity-0 group-hover/chip:opacity-100 transition-opacity duration-150 pointer-events-none z-20">
                      {skill.note}
                    </span>
                  )}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
      <div class="mt-5 flex items-center justify-center gap-6 text-xs text-appleGray/70">
        <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-appleBlue inline-block"></span>熟練</span>
        <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-appleGray/50 inline-block"></span>習熟</span>
        <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-appleDark/20 inline-block"></span>基礎</span>
        <span class="hidden md:inline text-appleGray/55">— ホバーで詳細表示</span>
      </div>
    </section>

    <!-- Research (all — only 2 items) -->
    <section id="research" class="max-w-5xl mx-auto mb-32 fade-in-section">
      <div class="mb-8">
        <h2 class="text-3xl font-bold mb-2 text-appleDark tracking-tight">Research</h2>
        <div class="w-12 h-1 bg-appleBlue rounded-full"></div>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {allResearch.map(item => (
          <ProjectCard
            title={item.data.title}
            summary={item.data.summary}
            image={item.data.hero}
            stack={item.data.stack}
            highlights={item.data.highlights}
            href={`${b}research/${item.id.replace('ja/', '')}/`}
            isResearch={true}
          />
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href={`${b}research/`} class="inline-flex items-center px-6 py-2.5 glass-button rounded-full text-sm font-medium text-appleDark hover:text-appleBlue transition-all">
          すべて見る（全{allResearch.length}件）<i class="fa-solid fa-arrow-right ml-1.5 text-xs"></i>
        </a>
      </div>
    </section>

    <!-- Projects (featured top 3) -->
    <section id="projects" class="max-w-5xl mx-auto mb-32 fade-in-section">
      <div class="mb-8">
        <h2 class="text-3xl font-bold mb-2 text-appleDark tracking-tight">Projects</h2>
        <div class="w-12 h-1 bg-appleBlue rounded-full"></div>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {featuredProjects.map(project => (
          <ProjectCard
            title={project.data.title}
            summary={project.data.summary}
            image={project.data.hero}
            stack={project.data.stack}
            highlights={project.data.highlights}
            href={`${b}projects/${project.id.replace('ja/', '')}/`}
          />
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href={`${b}projects/`} class="inline-flex items-center px-6 py-2.5 glass-button rounded-full text-sm font-medium text-appleDark hover:text-appleBlue transition-all">
          すべて見る（全{allProjects.length}件）<i class="fa-solid fa-arrow-right ml-1.5 text-xs"></i>
        </a>
      </div>
    </section>

    <!-- Achievements (top 4) -->
    <section id="achievements" class="max-w-5xl mx-auto mb-32 fade-in-section">
      <div class="mb-8">
        <h2 class="text-3xl font-bold mb-2 text-appleDark tracking-tight">Achievements</h2>
        <div class="w-12 h-1 bg-appleBlue rounded-full"></div>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {data.achievements.slice(0, 4).map((ach, i) => (
          <AchievementCard
            idx={i}
            title={ach.title}
            date={ach.date}
            summary={ach.summary}
          />
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href={`${b}achievements/`} class="inline-flex items-center px-6 py-2.5 glass-button rounded-full text-sm font-medium text-appleDark hover:text-appleBlue transition-all">
          すべて見る（全{data.achievements.length}件）<i class="fa-solid fa-arrow-right ml-1.5 text-xs"></i>
        </a>
      </div>
    </section>

    <!-- Blog -->
    <section id="blog" class="max-w-5xl mx-auto mb-32 fade-in-section">
      <div class="mb-8">
        <h2 class="text-3xl font-bold mb-2 text-appleDark tracking-tight">Blog</h2>
        <div class="w-12 h-1 rounded-full" style="background:#7c3aed;"></div>
      </div>
      {latestPosts.length === 0 ? (
        <div class="glass-panel p-12 text-center">
          <i class="fa-solid fa-pen-nib text-3xl mb-4" style="color:rgba(124,58,237,0.25);"></i>
          <p class="text-appleGray text-sm">記事はまだありません</p>
        </div>
      ) : (
        <>
          <div class="grid md:grid-cols-3 gap-6">
            {latestPosts.map(post => (
              <BlogCard
                title={post.data.title}
                summary={post.data.summary}
                date={post.data.date}
                tags={post.data.tags}
                slug={post.id}
                thumbnail={post.data.thumbnail}
              />
            ))}
          </div>
          <div class="mt-8 text-center">
            <a href={`${b}blog/`} class="inline-flex items-center px-6 py-2.5 glass-button rounded-full text-sm font-medium transition-all hover:opacity-80" style="color:#7c3aed;">
              すべて見る（全{allPosts.length}件）<i class="fa-solid fa-arrow-right ml-1.5 text-xs"></i>
            </a>
          </div>
        </>
      )}
    </section>

    <!-- Experience & Education -->
    <section id="experience" class="max-w-4xl mx-auto mb-32 fade-in-section">
      <h2 class="text-3xl font-bold mb-2 text-appleDark tracking-tight">Experience & Education</h2>
      <div class="w-12 h-1 bg-appleBlue rounded-full mb-10"></div>
      <div class="border-l-2 border-appleBlue/20 ml-3 md:ml-6 relative pb-6 space-y-10">
        {data.timeline.map(item => (
          <div class="relative pl-8 md:pl-10">
            <div class="absolute -left-[9px] top-1.5 w-4 h-4 rounded-full bg-appleBlue/60 border-2 border-white shadow-sm"></div>
            <span class="text-xs font-semibold text-appleBlue tracking-wider">{item.year}</span>
            <h3 class="text-lg font-bold text-appleDark mt-0.5">{item.title}</h3>
            {item.subtitle && <p class="text-sm font-medium text-appleGray">{item.subtitle}</p>}
            <p class="text-sm text-appleDark/70 mt-2 leading-relaxed">{item.description}</p>
          </div>
        ))}
        <svg class="absolute top-full left-[-9px] overflow-visible" width="16" height="14" viewBox="0 0 16 14" fill="none" style="color: rgba(0,102,204,0.25);">
          <line x1="8" y1="0" x2="8" y2="12" stroke="currentColor" stroke-width="2"/>
          <path d="M2 6 L8 12 L14 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="max-w-3xl mx-auto mb-20 fade-in-section text-center">
      <div class="glass-panel p-12 flex flex-col items-center">
        <h2 class="text-3xl font-bold mb-6 text-appleDark tracking-tight">Get In Touch</h2>
        <p class="text-appleDark/80 mb-10 text-lg max-w-lg leading-relaxed">{data.contactText}</p>
        <a href={`mailto:${data.profile.email}`}
           class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold rounded-full text-white bg-appleDark hover:bg-black transition-all shadow-lg hover:shadow-xl hover:-translate-y-1">
          <i class="fa-regular fa-envelope mr-2"></i>メールを送る
        </a>
        <div class="mt-12 flex justify-center space-x-6">
          {data.socials.map(s => (
            <a href={s.url} target="_blank" rel="noopener noreferrer" aria-label={s.name}
               class="w-12 h-12 flex items-center justify-center glass-button rounded-full text-appleGray hover:text-appleBlue hover:scale-110 transition-all text-lg">
              <i class={s.icon}></i>
            </a>
          ))}
        </div>
      </div>
    </section>

  </main>

  <Footer socials={data.socials} lang="ja" />
</Layout>

<script define:vars={{ achData }}>
  window.__achievementsData = achData;
</script>
