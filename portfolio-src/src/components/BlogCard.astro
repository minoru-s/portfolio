---
interface Props {
  title: string;
  summary: string;
  date: Date;
  tags: string[];
  slug: string;
  thumbnail?: string;
}

const { title, summary, date, tags, slug, thumbnail } = Astro.props;

const formattedDate = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Tag-based placeholder gradient
const tagGradients: Record<string, string> = {
  'エッセイ': 'linear-gradient(135deg, rgba(245,158,11,0.12) 0%, rgba(239,68,68,0.08) 100%)',
  'Essay':   'linear-gradient(135deg, rgba(245,158,11,0.12) 0%, rgba(239,68,68,0.08) 100%)',
  'UI/UX':   'linear-gradient(135deg, rgba(124,58,237,0.1) 0%, rgba(0,102,204,0.08) 100%)',
  '情報設計': 'linear-gradient(135deg, rgba(124,58,237,0.1) 0%, rgba(0,102,204,0.08) 100%)',
  'Web':     'linear-gradient(135deg, rgba(0,102,204,0.1) 0%, rgba(16,185,129,0.08) 100%)',
  'Frontend':'linear-gradient(135deg, rgba(0,102,204,0.1) 0%, rgba(16,185,129,0.08) 100%)',
};
const placeholderGradient = tagGradients[tags[0]] ?? 'linear-gradient(135deg, rgba(100,116,139,0.1) 0%, rgba(100,116,139,0.05) 100%)';

const placeholderIcons: Record<string, string> = {
  'エッセイ': 'fa-feather-pointed',
  'Essay':   'fa-feather-pointed',
  'UI/UX':   'fa-pen-ruler',
  '情報設計': 'fa-sitemap',
  'Web':     'fa-code',
  'Frontend':'fa-code',
};
const placeholderIcon = placeholderIcons[tags[0]] ?? 'fa-pen-nib';
const b = import.meta.env.BASE_URL;
const resolvedThumbnail = thumbnail?.startsWith('/') ? `${b}${thumbnail.slice(1)}` : thumbnail;
---

<a href={`${import.meta.env.BASE_URL}blog/${slug}/`} class="glass-panel flex flex-col overflow-hidden rounded-2xl hover:-translate-y-1 hover:shadow-lg transition-all duration-200" style="text-decoration:none;color:inherit;">
  <!-- Thumbnail -->
  <div class="relative overflow-hidden" style="aspect-ratio:16/9;">
    {thumbnail ? (
      <img
        src={resolvedThumbnail}
        alt={title}
        class="w-full h-full object-cover"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
      />
      <div class="absolute inset-0 items-center justify-center hidden" style={`background:${placeholderGradient};`}>
        <i class={`fa-solid ${placeholderIcon} text-3xl opacity-20`}></i>
      </div>
    ) : (
      <div class="absolute inset-0 flex items-center justify-center" style={`background:${placeholderGradient};`}>
        <i class={`fa-solid ${placeholderIcon} text-3xl opacity-20`}></i>
      </div>
    )}
  </div>

  <!-- Body -->
  <div class="p-5 flex flex-col flex-1">
    <div class="flex flex-wrap gap-1.5 mb-3">
      {tags.slice(0, 2).map(tag => (
        <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full" style="background:rgba(0,102,204,0.08);color:#0066cc;">{tag}</span>
      ))}
    </div>
    <h3 class="font-bold text-appleDark text-sm leading-snug mb-2 line-clamp-2 flex-1">{title}</h3>
    <p class="text-xs text-appleGray line-clamp-2 mb-3 leading-relaxed">{summary}</p>
    <p class="text-[10px] text-appleDark/35 mt-auto">{formattedDate}</p>
  </div>
</a>
