---
interface Props {
  currentLang: 'ja' | 'en';
  currentPath?: string;
}

const { currentLang, currentPath = '' } = Astro.props;

const b = import.meta.env.BASE_URL;
const base = currentLang === 'ja' ? b.slice(0, -1) : `${b}en`;
const toggleHref = currentLang === 'ja' ? `${b}en/` : b;
const toggleLabel = currentLang === 'ja' ? 'EN' : 'JA';

const navLinks = [
  { href: currentLang === 'ja' ? b : `${b}en/`, label: 'Home' },
  { href: `${base}/#about`,        label: 'About' },
  { href: `${base}/research/`,     label: 'Research' },
  { href: `${base}/projects/`,     label: 'Projects' },
  { href: `${base}/achievements/`, label: 'Achievements' },
  ...(currentLang === 'ja' ? [{ href: `${b}blog/`, label: 'Blog' }] : []),
  { href: `${base}/#contact`,      label: 'Contact' },
];
---

<div id="nav-container" class="fixed w-full left-0 z-50 top-4 px-4 flex justify-center pointer-events-none">
  <nav class="glass-nav rounded-full py-3 px-6 md:px-8 w-full max-w-5xl flex justify-between items-center pointer-events-auto">
    <a href={currentLang === 'ja' ? b : `${b}en/`} class="text-xl font-bold tracking-tight text-appleDark hover:text-appleBlue transition-colors">
      Minoru.
    </a>

    <div class="hidden md:flex space-x-5 lg:space-x-7 text-sm font-medium text-appleDark">
      {navLinks.map(link => (
        <a href={link.href} class="hover:text-appleBlue transition-colors">{link.label}</a>
      ))}
    </div>

    <div class="flex items-center space-x-3">
      <a href={toggleHref} class="text-sm font-bold text-appleDark hover:text-appleBlue border border-appleDark/20 rounded-full px-3 py-1 transition-colors">
        {toggleLabel}
      </a>
      <button id="mobile-menu-btn" class="md:hidden flex items-center justify-center w-8 h-8 text-2xl text-appleDark focus:outline-none" aria-label="Menu">
        <i class="fa-solid fa-bars" style="transition:transform 0.25s ease;display:block;"></i>
      </button>
    </div>
  </nav>
</div>

<!-- Mobile Menu -->
<div id="mobile-menu" class="fixed inset-0 z-40 hidden flex-col items-center justify-center space-y-8 text-xl font-medium glass-panel rounded-none">
  <button id="mobile-close-btn" class="absolute top-6 right-6 text-2xl text-appleDark" aria-label="Close">
    <i class="fa-solid fa-xmark"></i>
  </button>
  {navLinks.map(link => (
    <a href={link.href} class="mobile-link text-appleDark hover:text-appleBlue transition-colors">{link.label}</a>
  ))}
  <a href={toggleHref} class="mt-4 text-sm font-bold text-appleDark hover:text-appleBlue border border-appleDark/20 rounded-full px-4 py-2 transition-colors">
    {toggleLabel}
  </a>
</div>

<script is:inline>
  (function () {
    const btn = document.getElementById('mobile-menu-btn');
    const closeBtn = document.getElementById('mobile-close-btn');
    const menu = document.getElementById('mobile-menu');

    var menuIcon = btn ? btn.querySelector('i') : null;

    function openMenu() {
      document.body.style.overflow = 'hidden';
      menu.classList.remove('hidden');
      menu.classList.add('flex');
      if (menuIcon) {
        menuIcon.className = 'fa-solid fa-xmark';
        menuIcon.style.transform = 'rotate(90deg)';
      }
    }

    function closeMenu() {
      menu.classList.add('hidden');
      menu.classList.remove('flex');
      document.body.style.overflow = '';
      if (menuIcon) {
        menuIcon.className = 'fa-solid fa-bars';
        menuIcon.style.transform = '';
      }
    }

    btn?.addEventListener('click', function() {
      menu.classList.contains('hidden') ? openMenu() : closeMenu();
    });
    closeBtn?.addEventListener('click', closeMenu);

    // Close when clicking the menu backdrop (not the links/buttons inside)
    menu?.addEventListener('click', function(e) {
      if (e.target === menu) closeMenu();
    });

    document.querySelectorAll('.mobile-link').forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  })();
</script>
