<div id="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div id="modal-backdrop"></div>
  <div id="modal-box">
    <!-- Drag handle (mobile) -->
    <div style="display:flex;justify-content:center;padding:12px 0 8px;flex-shrink:0;" class="sm:hidden">
      <div style="width:40px;height:4px;border-radius:9999px;background:rgba(29,29,31,0.18);"></div>
    </div>

    <!-- Header -->
    <div style="display:flex;align-items:flex-start;justify-content:space-between;padding:16px 24px;flex-shrink:0;border-bottom:1px solid rgba(0,0,0,0.06);">
      <h3 id="modal-title" style="font-size:1.35rem;font-weight:700;color:#1d1d1f;line-height:1.3;padding-right:12px;"></h3>
      <button id="modal-close" aria-label="閉じる"
              style="flex-shrink:0;width:34px;height:34px;display:flex;align-items:center;justify-content:center;border-radius:9999px;border:none;background:transparent;cursor:pointer;color:#86868b;transition:background 150ms,color 150ms;"
              onmouseover="this.style.background='rgba(0,0,0,0.07)';this.style.color='#1d1d1f'"
              onmouseout="this.style.background='transparent';this.style.color='#86868b'">
        <i class="fa-solid fa-xmark" style="font-size:1.1rem;"></i>
      </button>
    </div>

    <!-- Scrollable body -->
    <div style="flex:1;overflow-y:auto;overscroll-behavior:contain;">
      <!-- Hero image (projects / research) -->
      <div id="modal-image-wrap" style="display:none;">
        <img id="modal-image" alt="" style="width:100%;height:220px;object-fit:cover;display:block;" />
      </div>

      <div style="padding:24px;">
        <!-- Date badge (achievements) -->
        <p id="modal-date" style="display:none;font-size:0.7rem;font-weight:700;color:#0066cc;letter-spacing:0.08em;margin-bottom:10px;"></p>

        <!-- Summary -->
        <p id="modal-summary" style="font-size:0.875rem;color:rgba(29,29,31,0.8);line-height:1.7;margin-bottom:20px;"></p>

        <!-- Highlights (projects / research) -->
        <ul id="modal-highlights" style="display:none;list-style:none;padding:0;margin:0 0 20px;background:rgba(0,102,204,0.05);border:1px solid rgba(0,102,204,0.15);border-radius:14px;padding:16px 18px;"></ul>

        <!-- Stack chips (projects / research) -->
        <div id="modal-stack" style="display:none;flex-wrap:wrap;gap:8px;margin-bottom:20px;"></div>

        <!-- Achievement full details -->
        <div id="modal-details" style="display:none;font-size:0.875rem;color:rgba(29,29,31,0.8);line-height:1.7;"></div>
      </div>
    </div>

    <!-- Footer CTA (projects / research) -->
    <div id="modal-footer" style="display:none;padding:16px 24px 24px;flex-shrink:0;text-align:center;border-top:1px solid rgba(0,0,0,0.06);">
      <a id="modal-cta" href="#"
         style="display:inline-flex;align-items:center;justify-content:center;padding:11px 32px;max-width:340px;background:rgba(0,0,0,0.06);color:#1d1d1f;border:1px solid rgba(0,0,0,0.12);border-radius:9999px;font-weight:600;font-size:0.875rem;text-decoration:none;transition:background 150ms,border-color 150ms,transform 150ms;"
         onmouseover="this.style.background='rgba(0,102,204,0.08)';this.style.borderColor='rgba(0,102,204,0.3)';this.style.color='#0066cc';this.style.transform='translateY(-1px)'"
         onmouseout="this.style.background='rgba(0,0,0,0.06)';this.style.borderColor='rgba(0,0,0,0.12)';this.style.color='#1d1d1f';this.style.transform=''">
        <span id="modal-cta-label">さらに詳しく</span>
        <i class="fa-solid fa-arrow-right" style="margin-left:8px;font-size:0.7rem;"></i>
      </a>
    </div>
  </div>
</div>

<style is:global>
  /* ① prevent scrollbar-width jump */
  html { scrollbar-gutter: stable; }

  #modal-overlay {
    display: flex;
    position: fixed;
    inset: 0;
    z-index: 60;
    align-items: flex-end;
    justify-content: center;
    padding: 0;
    visibility: hidden;
    pointer-events: none;
  }
  @media (min-width: 640px) {
    #modal-overlay { align-items: center; padding: 24px; }
  }
  #modal-overlay.is-open { visibility: visible; pointer-events: auto; }

  /* ② smooth backdrop */
  #modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(29, 29, 31, 0.42);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    opacity: 0;
    transition: opacity 360ms ease;
  }
  #modal-overlay.is-open #modal-backdrop { opacity: 1; }

  #modal-box {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 54rem;
    max-height: 92vh;
    display: flex;
    flex-direction: column;
    border-radius: 24px 24px 0 0;
    overflow: hidden;
    background: rgba(249, 249, 251, 0.97);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.65);
    box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.28), 0 0 0 1px rgba(0,0,0,0.04);
    opacity: 0;
    transform: translateY(100%);
    /* ② box appears 90ms after backdrop starts */
    transition: opacity 280ms ease 90ms, transform 400ms cubic-bezier(0.34, 1.56, 0.64, 1) 90ms;
  }
  /* Mobile: no spring bounce, simple ease-out */
  @media (max-width: 639px) {
    #modal-box {
      transition: opacity 240ms ease 90ms, transform 300ms cubic-bezier(0.25, 0.46, 0.45, 0.94) 90ms;
    }
  }
  @media (min-width: 640px) {
    #modal-box {
      border-radius: 20px;
      transform: scale(0.93) translateY(12px);
    }
    #modal-overlay.is-open #modal-box {
      transform: scale(1) translateY(0);
    }
  }
  #modal-overlay.is-open #modal-box {
    opacity: 1;
    transform: translateY(0);
  }

  /* Achievement details HTML styling */
  #modal-details h4 { font-weight: 700; color: #1d1d1f; margin: 16px 0 8px; font-size: 0.875rem; }
  /* Only underline text-level links (inside <p> or <li>), not block card links */
  #modal-details p a, #modal-details li a { color: #0066cc; text-decoration: underline; }
  /* Don't override inline-style YouTube embeds */
  #modal-details iframe { border: none; }
  #modal-details img { border-radius: 8px; }
  #modal-details ul { padding-left: 0; list-style: none; }
</style>

<script is:inline>
(function () {
  var overlay = document.getElementById('modal-overlay');
  var backdrop = document.getElementById('modal-backdrop');
  var box = document.getElementById('modal-box');
  var closeBtn = document.getElementById('modal-close');
  var closeTimer = null;

  function openModal(data) {
    // ① Compensate scrollbar width (add on top of existing padding, don't replace)
    var sbWidth = window.innerWidth - document.documentElement.clientWidth;
    if (sbWidth > 0) {
      document.body.style.paddingRight = sbWidth + 'px';
      var nav = document.getElementById('nav-container');
      if (nav) {
        var currentPR = parseFloat(getComputedStyle(nav).paddingRight) || 0;
        nav.style.paddingRight = (currentPR + sbWidth) + 'px';
      }
    }
    document.body.style.overflow = 'hidden';

    if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }

    // Populate
    document.getElementById('modal-title').textContent = data.title || '';

    var dateEl = document.getElementById('modal-date');
    if (data.date) { dateEl.textContent = data.date; dateEl.style.display = 'block'; }
    else { dateEl.style.display = 'none'; }

    var summaryEl = document.getElementById('modal-summary');
    summaryEl.textContent = data.summary || '';
    summaryEl.style.display = data.detailsHtml ? 'none' : '';

    var imgWrap = document.getElementById('modal-image-wrap');
    var imgEl  = document.getElementById('modal-image');
    if (data.image) { imgEl.src = data.image; imgEl.alt = data.title || ''; imgWrap.style.display = 'block'; }
    else { imgWrap.style.display = 'none'; }

    var hlEl = document.getElementById('modal-highlights');
    if (data.highlights && data.highlights.length) {
      hlEl.innerHTML = data.highlights.map(function(h) {
        return '<li style="display:flex;align-items:flex-start;gap:10px;font-size:0.85rem;color:rgba(29,29,31,0.82);margin-bottom:8px;line-height:1.5;">'
          + '<i class="fa-solid fa-check" style="color:#0066cc;font-size:0.7rem;margin-top:4px;flex-shrink:0;"></i>'
          + '<span>' + h + '</span></li>';
      }).join('');
      hlEl.style.display = 'block';
    } else { hlEl.style.display = 'none'; }

    var stackEl = document.getElementById('modal-stack');
    if (data.stack && data.stack.length) {
      stackEl.innerHTML = data.stack.map(function(t) {
        return '<span style="padding:4px 11px;border-radius:9999px;font-size:0.75rem;font-weight:500;color:rgba(29,29,31,0.65);background:rgba(0,0,0,0.06);border:1px solid rgba(0,0,0,0.09);">' + t + '</span>';
      }).join('');
      stackEl.style.display = 'flex';
    } else { stackEl.style.display = 'none'; }

    var detailsEl = document.getElementById('modal-details');
    if (data.detailsHtml) { detailsEl.innerHTML = data.detailsHtml; detailsEl.style.display = 'block'; }
    else { detailsEl.style.display = 'none'; }

    var footer = document.getElementById('modal-footer');
    var cta = document.getElementById('modal-cta');
    var ctaLabel = document.getElementById('modal-cta-label');
    if (data.href) {
      cta.href = data.href;
      ctaLabel.textContent = data.ctaLabel || 'さらに詳しく';
      footer.style.display = 'block';
    } else { footer.style.display = 'none'; }

    // ② Smooth open
    overlay.classList.add('is-open');
  }

  function closeModal() {
    // Remove iframe from DOM immediately to stop any playing audio/video
    document.getElementById('modal-details').innerHTML = '';
    overlay.classList.remove('is-open');
    closeTimer = setTimeout(function() {
      document.body.style.overflow = '';
      document.body.style.paddingRight = '';
      var nav = document.getElementById('nav-container');
      if (nav) nav.style.paddingRight = '';
    }, 400);
  }

  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });

  // Project / research card triggers
  document.querySelectorAll('[data-modal]').forEach(function(card) {
    card.addEventListener('click', function() {
      openModal(JSON.parse(card.dataset.modal));
    });
  });

  // Achievement card triggers
  document.querySelectorAll('[data-achievement-idx]').forEach(function(card) {
    card.addEventListener('click', function() {
      var idx = parseInt(card.dataset.achievementIdx, 10);
      var achData = window.__achievementsData;
      if (achData && achData[idx]) {
        openModal({ title: achData[idx].title, date: achData[idx].date, summary: achData[idx].summary, detailsHtml: achData[idx].details });
      }
    });
  });

  window.openModal = openModal;
  window.closeModal = closeModal;
})();
</script>
